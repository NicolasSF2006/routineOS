+function cloneRoutineDraft(routine: Routine | null): Routine | null {
+  return routine ? (JSON.parse(JSON.stringify(routine)) as Routine) : null
+}
+
+function getConflictedBlockIds(blocks: RoutineBlock[], fallbackStartMinutes: number): Set<string> {
+  const conflictedIds = new Set<string>()
+
+  for (let firstIndex = 0; firstIndex < blocks.length; firstIndex += 1) {
+    const firstBlock = blocks[firstIndex]
+    const firstStart = getBlockStartMinutes(firstBlock, fallbackStartMinutes)
+    const firstEnd = firstStart + Math.max(1, firstBlock.durationMinutes)
+
+    for (let secondIndex = firstIndex + 1; secondIndex < blocks.length; secondIndex += 1) {
+      const secondBlock = blocks[secondIndex]
+      const secondStart = getBlockStartMinutes(secondBlock, fallbackStartMinutes)
+      const secondEnd = secondStart + Math.max(1, secondBlock.durationMinutes)
+      const hasConflict = firstStart < secondEnd && secondStart < firstEnd
+
+      if (hasConflict) {
+        conflictedIds.add(firstBlock.id)
+        conflictedIds.add(secondBlock.id)
+      }
+    }
+  }
+
+  return conflictedIds
+}
+
+function getWeekdayConflictLabel(weekday: Weekday): string {
+  const weekdayName = getWeekdayRepeatName(weekday)
+  const article = weekday === "saturday" || weekday === "sunday" ? "no" : "na"
+
+  return `${article} ${weekdayName}`
+}
+
+function joinPortugueseList(items: string[]): string {
+  if (items.length <= 1) return items[0] ?? ""
+  if (items.length === 2) return `${items[0]} e ${items[1]}`
+
+  return `${items.slice(0, -1).join(", ")} e ${items[items.length - 1]}`
+}
+
+function removeBlocksFromRoutine(
+  routine: Routine,
+  shouldRemoveBlock: (block: RoutineBlock) => boolean,
+): Routine {
+  const normalizeDay = (day: RoutineDay): RoutineDay => {
+    const blocks = day.blocks.filter((block) => !shouldRemoveBlock(block))
+
+    return {
+      ...day,
+      blocks,
+      isActive: blocks.length > 0,
+    }
+  }
+
+  return {
+    ...routine,
+    days: routine.days.map(normalizeDay),
+    weeks: routine.weeks?.map((week) => ({
+      ...week,
+      days: week.days.map(normalizeDay),
+    })),
+  }
+}
